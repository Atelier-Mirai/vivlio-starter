# 一般的な無視ファイル（例: node_modules/, build/ など）
.env
log/
tmp/
node_modules/
*.log
*.tmp
.DS_Store
Thumbs.db
*.pdf
*.epub
*.kpf

# RubyGem artifacts
*.gem
pkg/*.gem

# Vivlio Starter artifacts
# （covers/ はソースのみになったため無視しない。生成物は /.cache/ 配下に出る）
/.cache/
# 表紙の編集ソース（Keynote 等）は大きい作業ファイルのため追跡しない
*.key

# Vivlio Starter 中間生成ファイル（vs build が一時展開し、通常は最終 clean で削除される。
# --no-clean 実行時やビルド中断時に残ることがあるためコミット対象から除外する）
_toc.md
_toc.html
_part[0-9]*.md
_part[0-9]*.html
_index_matches.yml
_colophon.md
_colophon.html
_titlepage.md
_titlepage.html
_legalpage.md
_legalpage.html
_indexpage.html
_glossarypage.html
_index_glossary_review.md

# Vivliostyle build artifacts
/.vivliostyle/

vivlio_starter_v1.0.0_images/

# Kindle artifacts
/output/
