#!/usr/bin/env ruby
# frozen_string_literal: true

# Early re-exec with RUBYOPT=-W0 to suppress warnings from process start (incl. Bundler init)
# Skip when debugging/warnings enabled explicitly.
unless ENV['VS_DEBUG'] == '1' || ENV['VS_WARNINGS'] == '1' || ENV['VS_NO_REEXEC'] == '1'
  rubopt = (ENV['RUBYOPT'] || '')
  unless rubopt.split.include?('-W0')
    ENV['RUBYOPT'] = (['-W0'] + rubopt.split).join(' ')
    ENV['VS_NO_REEXEC'] = '1'
    # Prefer re-exec via bundler so dependency resolution stays intact
    begin
      exec('bundle', 'exec', RbConfig.ruby, __FILE__, *ARGV)
    rescue
      # Fallback: run without bundler
      exec(RbConfig.ruby, __FILE__, *ARGV)
    end
  end
end

APP_ROOT = File.expand_path('..', __dir__)
$LOAD_PATH.unshift(File.join(APP_ROOT, 'lib')) unless $LOAD_PATH.include?(File.join(APP_ROOT, 'lib'))

require 'vivlio/starter/cli'

Vivlio::Starter::CLI.start(ARGV)
